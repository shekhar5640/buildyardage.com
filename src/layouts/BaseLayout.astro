---
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  jsonLd?: Record<string, any>;
}

const { title, description, jsonLd } = Astro.props;

// Default structured data for the site if none provided
const defaultJsonLd = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "Build Yardage",
  "url": Astro.site ? Astro.site.toString() : "https://buildyardage.com",
  "description": "Premium, high-precision material calculators for contractors and DIY projects."
};

const activeJsonLd = jsonLd || defaultJsonLd;
---

<!doctype html>
<html lang="en" data-theme="light">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    
    <!-- SEO Meta Tags -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    
    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:site_name" content="Build Yardage" />

    <!-- Google Fonts for premium typography -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet">
    
    <!-- Inject JSON-LD Schema -->
    <script type="application/ld+json" is:inline set:html={JSON.stringify(activeJsonLd)} />

    <!-- Theme Initializer Script to prevent flashing -->
    <script is:inline>
      const getTheme = () => {
        if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
          return localStorage.getItem('theme');
        }
        if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
          return 'dark';
        }
        return 'light';
      };
      const theme = getTheme();
      document.documentElement.setAttribute('data-theme', theme);
    </script>
  </head>
  
  <body class="flex flex-col min-h-screen transition-colors duration-200 selection:bg-brand-accent selection:text-white">
    <!-- Header / Navigation -->
    <header class="no-print print:hidden sticky top-0 z-40 w-full border-b border-hairline bg-canvas/80 backdrop-blur-md transition-colors duration-200">
      <div class="mx-auto flex h-16 max-w-7xl items-center justify-between px-4 sm:px-6 lg:px-8">
        <!-- Logo / Wordmark -->
        <a href="/" class="flex items-center gap-2 group">
          <div class="flex h-8 w-8 items-center justify-center rounded-md bg-brand-primary text-on-primary group-hover:scale-105 transition-transform duration-200 font-bold text-lg select-none">
            BY
          </div>
          <span class="text-xl font-bold tracking-tight text-ink">
            Build<span class="text-brand-accent">Yardage</span>
          </span>
        </a>

        <!-- Main Navigation Links -->
        <nav class="hidden md:flex items-center gap-6">
          <a href="/calculators/concrete-slab-calculator" class="text-sm font-medium text-body hover:text-ink transition-colors">Concrete Slab</a>
          <a href="/calculators/concrete-column-calculator" class="text-sm font-medium text-body hover:text-ink transition-colors">Column / Post</a>
          <a href="/calculators/gravel-driveway-calculator" class="text-sm font-medium text-body hover:text-ink transition-colors">Gravel</a>
          <a href="/calculators/drywall-calculator" class="text-sm font-medium text-body hover:text-ink transition-colors">Drywall</a>
          <a href="/calculators/framing-calculator" class="text-sm font-medium text-body hover:text-ink transition-colors">Framing</a>
        </nav>

        <!-- Secondary Actions & Theme Toggle -->
        <div class="flex items-center gap-4">
          <button
            id="theme-toggle"
            aria-label="Toggle Theme"
            class="flex h-9 w-9 items-center justify-center rounded-md border border-hairline bg-canvas text-ink hover:bg-surface-soft transition-all active:scale-95 cursor-pointer"
          >
            <!-- Sun Icon (Light Mode) -->
            <svg id="sun-icon" class="hidden h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v1m0 16v1m9-9h-1M4 9h-1m15.364-6.364l-.707.707M6.343 17.657l-.707.707m12.728 0l-.707-.707M6.343 6.343l-.707-.707M12 8a4 4 0 100 8 4 4 0 000-8z" />
            </svg>
            <!-- Moon Icon (Dark Mode) -->
            <svg id="moon-icon" class="hidden h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
            </svg>
          </button>
        </div>
      </div>
    </header>

    <!-- Main Content Area -->
    <main class="flex-grow">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="no-print print:hidden bg-surface-dark text-on-dark-soft border-t border-zinc-800 transition-colors duration-200">
      <div class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8 lg:py-16">
        <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
          <!-- Brand Info -->
          <div class="space-y-4 md:col-span-2">
            <div class="flex items-center gap-2">
              <div class="flex h-7 w-7 items-center justify-center rounded bg-white text-black font-bold text-sm">
                BY
              </div>
              <span class="text-lg font-bold tracking-tight text-white">
                Build<span class="text-brand-accent">Yardage</span>
              </span>
            </div>
            <p class="text-sm text-zinc-400 max-w-md leading-relaxed">
              Build Yardage delivers premium, contractor-grade material calculators designed for speed, precision, and ease of use. Calculate quantities for concrete, gravel, drywall, framing, and more in seconds.
            </p>
          </div>

          <!-- Calculators Quick Links -->
          <div>
            <h3 class="text-sm font-semibold text-white tracking-wider uppercase">Calculators</h3>
            <ul class="mt-4 space-y-2">
              <li>
                <a href="/calculators/concrete-slab-calculator" class="text-sm text-zinc-400 hover:text-white transition-colors">Concrete Slab</a>
              </li>
              <li>
                <a href="/calculators/concrete-column-calculator" class="text-sm text-zinc-400 hover:text-white transition-colors">Concrete Column</a>
              </li>
              <li>
                <a href="/calculators/gravel-driveway-calculator" class="text-sm text-zinc-400 hover:text-white transition-colors">Gravel Base</a>
              </li>
              <li>
                <a href="/calculators/drywall-calculator" class="text-sm text-zinc-400 hover:text-white transition-colors">Drywall Panels</a>
              </li>
              <li>
                <a href="/calculators/framing-calculator" class="text-sm text-zinc-400 hover:text-white transition-colors">Wall Framing</a>
              </li>
            </ul>
          </div>

          <!-- Legal & Compliance -->
          <div>
            <h3 class="text-sm font-semibold text-white tracking-wider uppercase">Company</h3>
            <ul class="mt-4 space-y-2">
              <li>
                <a href="#" class="text-sm text-zinc-400 hover:text-white transition-colors">Privacy Policy</a>
              </li>
              <li>
                <a href="#" class="text-sm text-zinc-400 hover:text-white transition-colors">Terms of Service</a>
              </li>
              <li>
                <a href="#" class="text-sm text-zinc-400 hover:text-white transition-colors">Contact Support</a>
              </li>
            </ul>
          </div>
        </div>

        <!-- Disclaimer & Copyright -->
        <div class="mt-12 border-t border-zinc-800 pt-8 flex flex-col sm:flex-row items-center justify-between gap-4">
          <p class="text-xs text-zinc-500 leading-normal max-w-xl text-center sm:text-left">
            <strong class="text-zinc-400 block mb-1">Disclaimer:</strong>
            Our calculations are approximations. Consult a professional contractor before ordering materials. We are not liable for any discrepancies, excess ordering, or project issues resulting from the use of these tools.
          </p>
          <p class="text-xs text-zinc-500 shrink-0 font-mono">
            &copy; {new Date().getFullYear()} buildyardage.com. All rights reserved.
          </p>
        </div>
      </div>
    </footer>

    <!-- Theme Toggle Interaction Script -->
    <script>
      const toggle = document.getElementById('theme-toggle');
      const sunIcon = document.getElementById('sun-icon');
      const moonIcon = document.getElementById('moon-icon');

      const updateIcons = () => {
        const currentTheme = document.documentElement.getAttribute('data-theme');
        if (currentTheme === 'dark') {
          sunIcon?.classList.remove('hidden');
          moonIcon?.classList.add('hidden');
        } else {
          moonIcon?.classList.remove('hidden');
          sunIcon?.classList.add('hidden');
        }
      };

      // Set initial icon visibility
      updateIcons();

      toggle?.addEventListener('click', () => {
        const current = document.documentElement.getAttribute('data-theme');
        const next = current === 'dark' ? 'light' : 'dark';
        document.documentElement.setAttribute('data-theme', next);
        localStorage.setItem('theme', next);
        updateIcons();
      });
    </script>
  </body>
</html>
