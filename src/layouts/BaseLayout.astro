---
import '../styles/global.css';
import {
  getLocaleFromUrl,
  getTranslations,
  getHreflangLinks,
  getLocalizedPath,
  type SupportedLocale
} from '../i18n/utils';
import { LanguageSelector } from '../components/LanguageSelector';

interface Props {
  title: string;
  description: string;
  jsonLd?: Record<string, any>;
  lang?: SupportedLocale;
}

const { title, description, jsonLd, lang: propLang } = Astro.props;

const activeLocale = propLang || getLocaleFromUrl(Astro.url.pathname);
const t = getTranslations(activeLocale);
const hreflangLinks = getHreflangLinks(Astro.url.pathname);

// Default structured data for the site if none provided
const defaultJsonLd = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "Build Yardage",
  "url": Astro.site ? Astro.site.toString() : "https://buildyardage.com",
  "description": "Premium, high-precision material calculators for contractors and DIY projects."
};

const activeJsonLd = jsonLd || defaultJsonLd;

const currentPath = Astro.url.pathname.replace(/\/$/, "");
---

<!doctype html>
<html lang={activeLocale} data-theme="light">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    
    <!-- SEO Meta Tags -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <meta name="apple-mobile-web-app-title" content="BuildYard" />
    <link rel="manifest" href="/site.webmanifest" />
    
    <!-- Google SEO hreflang Alternate Tags -->
    {hreflangLinks.map((link) => (
      <link rel={link.rel} hreflang={link.hreflang} href={link.href} />
    ))}

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:site_name" content="Build Yardage" />

    <!-- Google Fonts for premium typography -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet">
    
    <!-- Inject JSON-LD Schema -->
    <script type="application/ld+json" is:inline set:html={JSON.stringify(activeJsonLd)} />

    <!-- Client-side Browser Language Detection & First-Time Redirect Script -->
    <script is:inline>
      (function() {
        try {
          var path = window.location.pathname;
          // Only trigger detection on root or index page
          if (path === '/' || path === '/index.html') {
            var isBot = /bot|googlebot|bingbot|slurp|duckduckbot|baiduspider|yandex/i.test(navigator.userAgent);
            if (!isBot) {
              var storedLocale = localStorage.getItem('user_locale');
              var supported = ['en', 'es', 'fr', 'de', 'pt', 'it', 'ja', 'zh'];
              var targetLocale = null;

              if (storedLocale && supported.indexOf(storedLocale) !== -1) {
                targetLocale = storedLocale;
              } else if (navigator.language) {
                var browserLang = navigator.language.split('-')[0].toLowerCase();
                if (supported.indexOf(browserLang) !== -1) {
                  targetLocale = browserLang;
                }
              }

              if (targetLocale && targetLocale !== 'en') {
                window.location.href = '/' + targetLocale + '/';
              }
            }
          }
        } catch (e) {}
      })();
    </script>

    <!-- Theme Initializer Script to prevent flashing -->
    <script is:inline>
      const getTheme = () => {
        if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
          return localStorage.getItem('theme');
        }
        if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
          return 'dark';
        }
        return 'light';
      };
      const theme = getTheme();
      document.documentElement.setAttribute('data-theme', theme);
    </script>
  </head>
  
  <body class="flex flex-col min-h-screen transition-colors duration-200 selection:bg-brand-accent selection:text-white">
    <!-- Header / Navigation -->
    <header class="no-print print:hidden sticky top-0 z-40 w-full border-b border-hairline bg-canvas/85 backdrop-blur-md transition-colors duration-200">
      <div class="mx-auto flex lg:grid lg:grid-cols-[auto_1fr_auto] xl:grid-cols-[1fr_auto_1fr] h-16 max-w-7xl items-center justify-between px-4 sm:px-6 lg:px-8 gap-4">
        <!-- Logo / Wordmark (Left Aligned) -->
        <div class="flex items-center justify-start shrink-0">
          <a href={getLocalizedPath('/', activeLocale)} class="flex items-center gap-2 group">
            <img src="/favicon.svg" alt="Build Yardage Logo" class="h-8 w-8 group-hover:scale-105 transition-transform duration-200 select-none" />
            <span class="text-xl font-bold tracking-tight text-ink">
              Build<span class="text-brand-accent">Yardage</span>
            </span>
          </a>
        </div>

        <!-- Main Navigation Links (Center Aligned on Laptops & Desktops) -->
        <nav class="hidden lg:flex items-center justify-center gap-3 xl:gap-6 h-full px-2">
          <a
            href={getLocalizedPath('/calculators/concrete-slab-calculator', activeLocale)}
            class={`text-xs xl:text-sm font-semibold whitespace-nowrap transition-all duration-150 border-b-2 py-5 -mb-px flex items-center ${
              currentPath.endsWith('/concrete-slab-calculator')
                ? 'text-brand-accent border-brand-accent'
                : 'text-body hover:text-ink border-transparent'
            }`}
          >
            {t.headerNav.concreteSlab}
          </a>
          <a
            href={getLocalizedPath('/calculators/concrete-column-calculator', activeLocale)}
            class={`text-xs xl:text-sm font-semibold whitespace-nowrap transition-all duration-150 border-b-2 py-5 -mb-px flex items-center ${
              currentPath.endsWith('/concrete-column-calculator')
                ? 'text-brand-accent border-brand-accent'
                : 'text-body hover:text-ink border-transparent'
            }`}
          >
            {t.headerNav.concreteColumn}
          </a>
          <a
            href={getLocalizedPath('/calculators/gravel-driveway-calculator', activeLocale)}
            class={`text-xs xl:text-sm font-semibold whitespace-nowrap transition-all duration-150 border-b-2 py-5 -mb-px flex items-center ${
              currentPath.endsWith('/gravel-driveway-calculator')
                ? 'text-brand-accent border-brand-accent'
                : 'text-body hover:text-ink border-transparent'
            }`}
          >
            {t.headerNav.gravel}
          </a>
          <a
            href={getLocalizedPath('/calculators/drywall-calculator', activeLocale)}
            class={`text-xs xl:text-sm font-semibold whitespace-nowrap transition-all duration-150 border-b-2 py-5 -mb-px flex items-center ${
              currentPath.endsWith('/drywall-calculator')
                ? 'text-brand-accent border-brand-accent'
                : 'text-body hover:text-ink border-transparent'
            }`}
          >
            {t.headerNav.drywall}
          </a>
          <a
            href={getLocalizedPath('/calculators/framing-calculator', activeLocale)}
            class={`text-xs xl:text-sm font-semibold whitespace-nowrap transition-all duration-150 border-b-2 py-5 -mb-px flex items-center ${
              currentPath.endsWith('/framing-calculator')
                ? 'text-brand-accent border-brand-accent'
                : 'text-body hover:text-ink border-transparent'
            }`}
          >
            {t.headerNav.framing}
          </a>
          <a
            href={getLocalizedPath('/calculators/rebar-calculator', activeLocale)}
            class={`text-xs xl:text-sm font-semibold whitespace-nowrap transition-all duration-150 border-b-2 py-5 -mb-px flex items-center ${
              currentPath.endsWith('/rebar-calculator')
                ? 'text-brand-accent border-brand-accent'
                : 'text-body hover:text-ink border-transparent'
            }`}
          >
            {t.headerNav.rebar}
          </a>
        </nav>

        <!-- Secondary Actions, Language Switcher & Theme Toggle (Right Aligned) -->
        <div class="flex items-center justify-end gap-2.5 shrink-0">
          <LanguageSelector client:load currentLocale={activeLocale} currentPathname={Astro.url.pathname} variant="header" />

          <button
            id="theme-toggle"
            aria-label="Toggle Theme"
            class="flex h-9 w-9 items-center justify-center rounded-md border border-hairline bg-canvas text-ink hover:bg-surface-soft transition-all active:scale-95 cursor-pointer min-h-[36px] min-w-[36px]"
          >
            <!-- Sun Icon (Light Mode) -->
            <svg id="sun-icon" class="hidden h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v1m0 16v1m9-9h-1M4 9h-1m15.364-6.364l-.707.707M6.343 17.657l-.707.707m12.728 0l-.707-.707M6.343 6.343l-.707-.707M12 8a4 4 0 100 8 4 4 0 000-8z" />
            </svg>
            <!-- Moon Icon (Dark Mode) -->
            <svg id="moon-icon" class="hidden h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
            </svg>
          </button>

          <!-- Mobile / Tablet Menu Hamburger Button -->
          <button
            id="mobile-menu-toggle"
            aria-label="Toggle Navigation Menu"
            aria-expanded="false"
            class="lg:hidden flex h-9 w-9 items-center justify-center rounded-md border border-hairline bg-canvas text-ink hover:bg-surface-soft transition-all active:scale-95 cursor-pointer min-h-[36px] min-w-[36px]"
          >
            <svg id="menu-icon" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
            </svg>
            <svg id="close-icon" class="hidden h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </button>
        </div>
      </div>

      <!-- Mobile & Tablet Navigation Drawer -->
      <div 
        id="mobile-menu" 
        class="hidden lg:hidden border-t border-hairline bg-canvas/95 backdrop-blur-md px-4 py-4 space-y-3 transition-all duration-200"
      >
        <div class="text-[10px] font-bold text-muted uppercase tracking-wider px-3 pb-1">Material Calculators</div>
        <a
          href={getLocalizedPath('/calculators/concrete-slab-calculator', activeLocale)}
          class={`block px-3.5 py-3 rounded-lg text-sm font-semibold transition-colors ${
            currentPath.endsWith('/concrete-slab-calculator')
              ? 'bg-brand-accent/10 text-brand-accent'
              : 'text-ink hover:bg-surface-soft'
          }`}
        >
          {t.nav.concreteSlab}
        </a>
        <a
          href={getLocalizedPath('/calculators/concrete-column-calculator', activeLocale)}
          class={`block px-3.5 py-3 rounded-lg text-sm font-semibold transition-colors ${
            currentPath.endsWith('/concrete-column-calculator')
              ? 'bg-brand-accent/10 text-brand-accent'
              : 'text-ink hover:bg-surface-soft'
          }`}
        >
          {t.nav.concreteColumn}
        </a>
        <a
          href={getLocalizedPath('/calculators/gravel-driveway-calculator', activeLocale)}
          class={`block px-3.5 py-3 rounded-lg text-sm font-semibold transition-colors ${
            currentPath.endsWith('/gravel-driveway-calculator')
              ? 'bg-brand-accent/10 text-brand-accent'
              : 'text-ink hover:bg-surface-soft'
          }`}
        >
          {t.nav.gravel}
        </a>
        <a
          href={getLocalizedPath('/calculators/drywall-calculator', activeLocale)}
          class={`block px-3.5 py-3 rounded-lg text-sm font-semibold transition-colors ${
            currentPath.endsWith('/drywall-calculator')
              ? 'bg-brand-accent/10 text-brand-accent'
              : 'text-ink hover:bg-surface-soft'
          }`}
        >
          {t.nav.drywall}
        </a>
        <a
          href={getLocalizedPath('/calculators/framing-calculator', activeLocale)}
          class={`block px-3.5 py-3 rounded-lg text-sm font-semibold transition-colors ${
            currentPath.endsWith('/framing-calculator')
              ? 'bg-brand-accent/10 text-brand-accent'
              : 'text-ink hover:bg-surface-soft'
          }`}
        >
          {t.nav.framing}
        </a>
        <a
          href={getLocalizedPath('/calculators/rebar-calculator', activeLocale)}
          class={`block px-3.5 py-3 rounded-lg text-sm font-semibold transition-colors ${
            currentPath.endsWith('/rebar-calculator')
              ? 'bg-brand-accent/10 text-brand-accent'
              : 'text-ink hover:bg-surface-soft'
          }`}
        >
          {t.nav.rebar}
        </a>

        <div class="px-3 pt-2">
          <LanguageSelector client:load currentLocale={activeLocale} currentPathname={Astro.url.pathname} variant="mobile" />
        </div>
      </div>
    </header>

    <!-- Main Content Area -->
    <main class="flex-grow">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="no-print print:hidden bg-surface-dark text-on-dark-soft border-t border-zinc-800 transition-colors duration-200">
      <div class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8 lg:py-16">
        <div class="grid grid-cols-1 md:grid-cols-4 gap-6">
          <!-- Brand Info -->
          <div class="space-y-4 md:col-span-2">
            <div class="flex items-center gap-2">
              <img src="/favicon.svg" alt="Build Yardage Logo" class="h-7 w-7 select-none" />
              <span class="text-lg font-bold tracking-tight text-white">
                Build<span class="text-brand-accent">Yardage</span>
              </span>
            </div>
            <p class="text-sm text-zinc-400 max-w-md leading-relaxed">
              {t.footer.description}
            </p>
            <div class="flex items-center gap-2 pt-1 text-sm text-zinc-400">
              <span class="text-zinc-500 font-semibold">{t.footer.contactLabel}</span>
              <a href="mailto:contact@buildyardage.com" class="text-brand-accent hover:underline font-mono text-xs sm:text-sm">
                contact@buildyardage.com
              </a>
            </div>
            <p class="text-xs text-zinc-500 font-mono pt-1">
              &copy; {new Date().getFullYear()} buildyardage.com. {t.common.copyright}
            </p>
          </div>

          <!-- Calculators Quick Links -->
          <div>
            <h3 class="text-sm font-semibold text-white tracking-wider uppercase">{t.footer.calculatorsTitle}</h3>
            <ul class="mt-4 space-y-2">
              <li>
                <a href={getLocalizedPath('/calculators/concrete-slab-calculator', activeLocale)} class="text-sm text-zinc-400 hover:text-white transition-colors">{t.nav.concreteSlab}</a>
              </li>
              <li>
                <a href={getLocalizedPath('/calculators/concrete-column-calculator', activeLocale)} class="text-sm text-zinc-400 hover:text-white transition-colors">{t.nav.concreteColumn}</a>
              </li>
              <li>
                <a href={getLocalizedPath('/calculators/gravel-driveway-calculator', activeLocale)} class="text-sm text-zinc-400 hover:text-white transition-colors">{t.nav.gravel}</a>
              </li>
              <li>
                <a href={getLocalizedPath('/calculators/drywall-calculator', activeLocale)} class="text-sm text-zinc-400 hover:text-white transition-colors">{t.nav.drywall}</a>
              </li>
              <li>
                <a href={getLocalizedPath('/calculators/framing-calculator', activeLocale)} class="text-sm text-zinc-400 hover:text-white transition-colors">{t.nav.framing}</a>
              </li>
              <li>
                <a href={getLocalizedPath('/calculators/rebar-calculator', activeLocale)} class="text-sm text-zinc-400 hover:text-white transition-colors">{t.nav.rebar}</a>
              </li>
            </ul>
          </div>

          <!-- Legal & Compliance -->
          <div class="space-y-4">
            <h3 class="text-sm font-semibold text-white tracking-wider uppercase">{t.footer.companyTitle}</h3>
            <ul class="space-y-2">
              <li>
                <a href={getLocalizedPath('/about', activeLocale)} class="text-sm text-zinc-400 hover:text-white transition-colors">{t.common.about}</a>
              </li>
              <li>
                <a href={getLocalizedPath('/privacy-policy', activeLocale)} class="text-sm text-zinc-400 hover:text-white transition-colors">{t.common.privacy}</a>
              </li>
              <li>
                <a href={getLocalizedPath('/terms-and-conditions', activeLocale)} class="text-sm text-zinc-400 hover:text-white transition-colors">{t.common.terms}</a>
              </li>
              <li>
                <a href={getLocalizedPath('/contact', activeLocale)} class="text-sm text-zinc-400 hover:text-white transition-colors">{t.common.contact}</a>
              </li>
            </ul>

            <div class="pt-2">
              <LanguageSelector client:load currentLocale={activeLocale} currentPathname={Astro.url.pathname} variant="footer" />
            </div>
          </div>
        </div>

        <!-- Disclaimer -->
        <div class="mt-12 border-t border-zinc-800 pt-8">
          <p class="text-xs text-zinc-500 leading-relaxed w-full">
            <strong class="text-zinc-400 block mb-1">{t.footer.disclaimerTitle}</strong>
            {t.footer.disclaimerText}
          </p>
        </div>
      </div>
    </footer>

    <!-- Theme Toggle Interaction Script -->
    <script>
      const toggle = document.getElementById('theme-toggle');
      const sunIcon = document.getElementById('sun-icon');
      const moonIcon = document.getElementById('moon-icon');

      const updateIcons = () => {
        const currentTheme = document.documentElement.getAttribute('data-theme');
        if (currentTheme === 'dark') {
          sunIcon?.classList.remove('hidden');
          moonIcon?.classList.add('hidden');
        } else {
          moonIcon?.classList.remove('hidden');
          sunIcon?.classList.add('hidden');
        }
      };

      // Set initial icon visibility
      updateIcons();

      toggle?.addEventListener('click', () => {
        const current = document.documentElement.getAttribute('data-theme');
        const next = current === 'dark' ? 'light' : 'dark';
        document.documentElement.setAttribute('data-theme', next);
        localStorage.setItem('theme', next);
        updateIcons();
      });

      // Mobile Menu Toggle Logic
      const mobileToggle = document.getElementById('mobile-menu-toggle');
      const mobileMenu = document.getElementById('mobile-menu');
      const menuIcon = document.getElementById('menu-icon');
      const closeIcon = document.getElementById('close-icon');

      mobileToggle?.addEventListener('click', () => {
        const isExpanded = mobileToggle.getAttribute('aria-expanded') === 'true';
        mobileToggle.setAttribute('aria-expanded', (!isExpanded).toString());
        if (isExpanded) {
          mobileMenu?.classList.add('hidden');
          menuIcon?.classList.remove('hidden');
          closeIcon?.classList.add('hidden');
        } else {
          mobileMenu?.classList.remove('hidden');
          menuIcon?.classList.add('hidden');
          closeIcon?.classList.remove('hidden');
        }
      });
    </script>
  </body>
</html>
