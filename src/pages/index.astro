---
import BaseLayout from '../layouts/BaseLayout.astro';
import { ChevronRight, HelpCircle } from 'lucide-react';

const faqItems = [
  {
    question: "How many 80lb bags of concrete are in a cubic yard?",
    answer: "There are exactly 45 bags of 80lb pre-mixed concrete in one cubic yard. One 80lb bag yields 0.60 cubic feet of mixed concrete, and 27 cubic feet (1 cubic yard) divided by 0.60 cu ft per bag equals 45 bags (before adding waste margins)."
  },
  {
    question: "How many tons of gravel are in a cubic yard?",
    answer: "There are approximately 1.4 short US tons (2,800 lbs) of crushed gravel or stone in one cubic yard based on standard loose aggregate density (1.40 tons per cu yd). Dense aggregates like crushed granite may reach 1.5 to 1.6 tons per cubic yard."
  },
  {
    question: "How much extra concrete, gravel, or framing material should I order for waste?",
    answer: "Industry standard practice is to order a 10% material waste margin. For concrete, this accounts for uneven sub-grade depth and form flex; for gravel, it covers compaction shrinkage (10%–15%); and for lumber and drywall, it compensates for cuts, headers, and scrap."
  },
  {
    question: "How do I calculate how many studs I need for a framing wall?",
    answer: "To calculate wall studs, convert wall length to inches and divide by stud spacing (16\" or 24\" on-center), then add 1 end stud. Next, add 2–3 extra studs per corner or wall intersection, plus double studs for window or door headers, and apply a 10% waste buffer."
  },
  {
    question: "How do I calculate how many drywall sheets I need for a room?",
    answer: "Calculate total surface area by multiplying wall perimeter by ceiling height, plus room length by width if including the ceiling. Divide total square footage by sheet coverage (32 sq ft for a 4x8 sheet or 48 sq ft for a 4x12 sheet), then add a 10% waste margin for window and door cutouts."
  }
];

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebSite",
      "name": "Build Yardage",
      "url": "https://buildyardage.com",
      "description": "High-precision material calculators for concrete slabs, columns, gravel tonnage, drywall, and wood framing."
    },
    {
      "@type": "FAQPage",
      "mainEntity": faqItems.map((item) => ({
        "@type": "Question",
        "name": item.question,
        "acceptedAnswer": {
          "@type": "Answer",
          "text": item.answer
        }
      }))
    }
  ]
};
---

<BaseLayout
  title="Build Yardage | Professional Aggregates & Material Calculators"
  description="High-precision material calculators for concrete slabs, columns, gravel tonnage, drywall, and wood framing. Built for contractors and DIY projects."
  jsonLd={jsonLd}
>
  <!-- Hero Section -->
  <section class="bg-canvas border-b border-hairline transition-colors duration-200">
    <div class="mx-auto max-w-7xl px-4 py-20 sm:px-6 lg:px-8 text-center">
      <h1 class="text-4xl font-extrabold tracking-tight text-ink sm:text-5xl md:text-6xl max-w-4xl mx-auto leading-[1.1] selection:bg-brand-accent">
        Build Faster, <span class="text-brand-accent">Calculate Without the Clutter</span>
      </h1>
      <p class="mt-6 text-lg text-muted max-w-2xl mx-auto leading-relaxed">
        The ultra-fast material calculator for the jobsite. Get instant, exact quantities for concrete, columns, aggregate, rebar, framing, and drywall.
      </p>
      
      <!-- CTA Button -->
      <div class="mt-10 flex justify-center gap-4">
        <a
          href="/calculators/concrete-slab-calculator"
          class="flex items-center gap-2 px-6 py-3 bg-brand-primary text-on-primary font-semibold rounded-md shadow hover:bg-brand-primary-active transition-all active:scale-95 duration-100"
        >
          <span>Try Concrete Slab Calc</span>
          <ChevronRight size={16} />
        </a>
        <a
          href="#directory"
          class="px-6 py-3 border border-hairline bg-canvas text-ink font-semibold rounded-md hover:bg-surface-soft transition-all active:scale-95 duration-100"
        >
          Browse All Calculators
        </a>
      </div>
    </div>
  </section>

  <!-- Calculator Directory Grid -->
  <section id="directory" class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8 transition-colors duration-200">
    <div class="border-b border-hairline pb-5 mb-8">
      <h2 class="text-2xl font-bold tracking-tight text-ink">Material Calculators</h2>
      <p class="text-sm text-muted mt-1">Select an estimator below to get started on your dimensions.</p>
    </div>

    <!-- Cards Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      
      <!-- CARD 1: Concrete Slab -->
      <a href="/calculators/concrete-slab-calculator" class="group bg-canvas border border-hairline hover:border-brand-accent rounded-lg p-6 flex flex-col justify-between hover:shadow-md transition-all duration-200">
        <div>
          <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-indigo-100 dark:bg-indigo-950/60 text-indigo-700 dark:text-indigo-400 mb-4 transition-colors">
            <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 4L21 8.5L12 13L3 8.5Z" />
              <path d="M3 8.5V14.5L12 19V13" />
              <path d="M21 8.5V14.5L12 19" />
            </svg>
          </div>
          <h3 class="text-md font-bold text-ink group-hover:text-brand-accent transition-colors">
            Concrete Slab Calculator
          </h3>
          <p class="text-xs text-muted mt-2 leading-relaxed">
            Estimate cubic yards, cubic feet, and individual pre-mix bag counts (80lb, 60lb, 40lb) for driveways, patios, and slabs with waste margins.
          </p>
        </div>
        <div class="flex items-center gap-1 text-xs font-semibold text-brand-accent mt-6 group-hover:translate-x-1 transition-transform">
          <span>Launch Slab Calc</span>
          <ChevronRight size={14} />
        </div>
      </a>

      <!-- CARD 2: Concrete Column -->
      <a href="/calculators/concrete-column-calculator" class="group bg-canvas border border-hairline hover:border-brand-accent rounded-lg p-6 flex flex-col justify-between hover:shadow-md transition-all duration-200">
        <div>
          <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-indigo-100 dark:bg-indigo-950/60 text-indigo-700 dark:text-indigo-400 mb-4 transition-colors">
            <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <ellipse cx="12" cy="6" rx="7" ry="2.5" />
              <path d="M5 6V18" />
              <path d="M19 6V18" />
              <path d="M5 18C5 19.38 8.13 20.5 12 20.5C15.87 20.5 19 19.38 19 18" />
            </svg>
          </div>
          <h3 class="text-md font-bold text-ink group-hover:text-brand-accent transition-colors">
            Concrete Column Calculator
          </h3>
          <p class="text-xs text-muted mt-2 leading-relaxed">
            Calculate cylinder volumes for Sonotubes, concrete pillars, fence post holes, and round footings in yards, meters, and bag counts.
          </p>
        </div>
        <div class="flex items-center gap-1 text-xs font-semibold text-brand-accent mt-6 group-hover:translate-x-1 transition-transform">
          <span>Launch Column Calc</span>
          <ChevronRight size={14} />
        </div>
      </a>

      <!-- CARD 3: Gravel Base -->
      <a href="/calculators/gravel-driveway-calculator" class="group bg-canvas border border-hairline hover:border-brand-accent rounded-lg p-6 flex flex-col justify-between hover:shadow-md transition-all duration-200">
        <div>
          <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-emerald-100 dark:bg-emerald-950/60 text-emerald-700 dark:text-emerald-400 mb-4 transition-colors">
            <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M4 21C7 15 8 10 10 3" />
              <path d="M20 21C17 15 16 10 14 3" />
              <path d="M12 21C12 17 12 13 12 9" stroke-dasharray="2 3" />
            </svg>
          </div>
          <h3 class="text-md font-bold text-ink group-hover:text-brand-accent transition-colors">
            Gravel Driveway Calculator
          </h3>
          <p class="text-xs text-muted mt-2 leading-relaxed">
            Determine gravel base tons and cubic yards for driveways, pathways, or sub-bases. Adjust aggregates material density metrics.
          </p>
        </div>
        <div class="flex items-center gap-1 text-xs font-semibold text-brand-accent mt-6 group-hover:translate-x-1 transition-transform">
          <span>Launch Gravel Calc</span>
          <ChevronRight size={14} />
        </div>
      </a>

      <!-- CARD 4: Drywall Panels -->
      <a href="/calculators/drywall-calculator" class="group bg-canvas border border-hairline hover:border-brand-accent rounded-lg p-6 flex flex-col justify-between hover:shadow-md transition-all duration-200">
        <div>
          <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-amber-100 dark:bg-amber-950/60 text-amber-800 dark:text-amber-400 mb-4 transition-colors">
            <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M7 3H19C19.55 3 20 3.45 20 4V16C20 16.55 19.55 17 19 17H7C6.45 17 6 16.55 6 16V4C6 3.45 6.45 3 7 3Z" opacity="0.4" />
              <rect x="4" y="7" width="13" height="14" rx="1" />
              <circle cx="6.5" cy="9.5" r="0.5" fill="currentColor" />
              <circle cx="14.5" cy="9.5" r="0.5" fill="currentColor" />
              <circle cx="6.5" cy="18.5" r="0.5" fill="currentColor" />
              <circle cx="14.5" cy="18.5" r="0.5" fill="currentColor" />
              <line x1="10.5" y1="7" x2="10.5" y2="21" stroke-dasharray="2 2" opacity="0.7" />
            </svg>
          </div>
          <h3 class="text-md font-bold text-ink group-hover:text-brand-accent transition-colors">
            Drywall Sheet Calculator
          </h3>
          <p class="text-xs text-muted mt-2 leading-relaxed">
            Estimate standard 4x8 or 4x12 panels for rooms or single walls. Compiles estimated joint tape feet, joint compound, and drywall screws.
          </p>
        </div>
        <div class="flex items-center gap-1 text-xs font-semibold text-brand-accent mt-6 group-hover:translate-x-1 transition-transform">
          <span>Launch Drywall Calc</span>
          <ChevronRight size={14} />
        </div>
      </a>

      <!-- CARD 5: Wall Framing -->
      <a href="/calculators/framing-calculator" class="group bg-canvas border border-hairline hover:border-brand-accent rounded-lg p-6 flex flex-col justify-between hover:shadow-md transition-all duration-200">
        <div>
          <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-purple-100 dark:bg-purple-950/60 text-purple-700 dark:text-purple-400 mb-4 transition-colors">
            <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M3 4H21" />
              <path d="M3 6.5H21" />
              <path d="M3 19.5H21" />
              <path d="M5 6.5V19.5" />
              <path d="M12 6.5V19.5" />
              <path d="M19 6.5V19.5" />
              <path d="M5 19.5L19 6.5" stroke-dasharray="3 2" opacity="0.7" />
            </svg>
          </div>
          <h3 class="text-md font-bold text-ink group-hover:text-brand-accent transition-colors">
            Wood Stud Wall Framing Calculator
          </h3>
          <p class="text-xs text-muted mt-2 leading-relaxed">
            Calculate total framing studs, single or double top plates, and bottom plates (16ft pieces) based on 16" or 24" spacing configurations.
          </p>
        </div>
        <div class="flex items-center gap-1 text-xs font-semibold text-brand-accent mt-6 group-hover:translate-x-1 transition-transform">
          <span>Launch Stud Calc</span>
          <ChevronRight size={14} />
        </div>
      </a>

      <!-- CARD 6: Rebar Grid -->
      <a href="/calculators/rebar-calculator" class="group bg-canvas border border-hairline hover:border-brand-accent rounded-lg p-6 flex flex-col justify-between hover:shadow-md transition-all duration-200">
        <div>
          <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-blue-100 dark:bg-blue-950/60 text-blue-700 dark:text-blue-400 mb-4 transition-colors">
            <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M3 8H21" />
              <path d="M3 16H21" />
              <path d="M8 3V21" />
              <path d="M16 3V21" />
              <circle cx="8" cy="8" r="1.5" fill="currentColor" />
              <circle cx="16" cy="8" r="1.5" fill="currentColor" />
              <circle cx="8" cy="16" r="1.5" fill="currentColor" />
              <circle cx="16" cy="16" r="1.5" fill="currentColor" />
            </svg>
          </div>
          <h3 class="text-md font-bold text-ink group-hover:text-brand-accent transition-colors">
            Rebar Grid Calculator
          </h3>
          <p class="text-xs text-muted mt-2 leading-relaxed">
            Estimate rebar grid spacing, total linear footage, pieces (sticks), and total weight by bar size (#3 to #8) with lap splice calculations.
          </p>
        </div>
        <div class="flex items-center gap-1 text-xs font-semibold text-brand-accent mt-6 group-hover:translate-x-1 transition-transform">
          <span>Launch Rebar Calc</span>
          <ChevronRight size={14} />
        </div>
      </a>

    </div>
  </section>

  <!-- Authoritative SEO Section for Search Indexation -->
  <section class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8 border-t border-hairline transition-colors duration-200 content-visibility-auto">
    <div class="bg-canvas border border-hairline rounded-xl p-8 sm:p-12 space-y-8">
      <div>
        <h2 class="text-3xl font-extrabold tracking-tight text-ink sm:text-4xl">
          Professional Construction Estimating: Precision Calculations for the Jobsite
        </h2>
        <p class="mt-3 text-sm text-body leading-relaxed">
          Accurate material estimating is the backbone of every profitable construction project, commercial pour, and home renovation. Ordering too little material causes costly jobsite delays, cold joints in concrete, and unexpected delivery fees. Ordering too much wastes capital and clutters your site. Build Yardage provides contractors, trade professionals, and DIY builders with instant, high-precision construction calculators designed strictly around standard building codes and ASTM reference metrics.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 border-t border-hairline pt-8">
        
        <!-- Pillar 1: Concrete Slab & Pre-Mix Bag Math -->
        <div class="space-y-3">
          <h3 class="text-lg font-bold text-ink flex items-center gap-2">
            <span class="text-brand-accent font-bold">1.</span>
            <a href="/calculators/concrete-slab-calculator" class="hover:text-brand-accent transition-colors">Concrete Slab & Pre-Mix Bag Math</a>
          </h3>
          <p class="text-xs text-muted leading-relaxed">
            Volumetric concrete math requires calculating length, width, and thickness in feet, then dividing total cubic feet by 27 to obtain cubic yards. For smaller pours requiring pre-mix bags, one cubic yard yields approximately 45 bags of 80lb concrete, 60 bags of 60lb concrete, or 90 bags of 40lb concrete. Always factor in a 10% waste buffer to account for uneven sub-grade excavation, ground settling, and formwork deflection to ensure you never run short mid-pour.
          </p>
        </div>

        <!-- Pillar 2: Sonotube Column & Footing Geometry -->
        <div class="space-y-3">
          <h3 class="text-lg font-bold text-ink flex items-center gap-2">
            <span class="text-brand-accent font-bold">2.</span>
            <a href="/calculators/concrete-column-calculator" class="hover:text-brand-accent transition-colors">Sonotube Column & Footing Geometry</a>
          </h3>
          <p class="text-xs text-muted leading-relaxed">
            Cylindrical footings, Sonotube cardboard forms, and round fence post holes follow strict cylinder volume geometry (Volume = π × r² × h). The radius represents half the hole diameter in feet, while height measures depth below grade. When pouring structural pier footings or deck posts, local building codes generally require extending footings at least 6 inches below your regional frost line to prevent ground heave. A 10% waste allowance accounts for auger hole flare and spillage.
          </p>
        </div>

        <!-- Pillar 3: Aggregate Weight & Gravel Base Tonnage -->
        <div class="space-y-3">
          <h3 class="text-lg font-bold text-ink flex items-center gap-2">
            <span class="text-brand-accent font-bold">3.</span>
            <a href="/calculators/gravel-driveway-calculator" class="hover:text-brand-accent transition-colors">Aggregate Weight & Gravel Base Tonnage</a>
          </h3>
          <p class="text-xs text-muted leading-relaxed">
            Quarries sell gravel, crushed stone, granite, and sand by weight in short US tons rather than cubic yards. Volume-to-weight conversions require multiplying cubic yards by specific aggregate material density factors. Standard crushed aggregate weighs approximately 1.40 tons per cubic yard (2,800 lbs/yd³). Compaction machinery reduces loose aggregate thickness by 10% to 15%. Laying heavy geotextile sub-base fabric beneath your driveway prevents stone loss into soft sub-grade soil over time.
          </p>
        </div>

        <!-- Pillar 4: Drywall Panel System & Finishing Supplies -->
        <div class="space-y-3">
          <h3 class="text-lg font-bold text-ink flex items-center gap-2">
            <span class="text-brand-accent font-bold">4.</span>
            <a href="/calculators/drywall-calculator" class="hover:text-brand-accent transition-colors">Drywall Panel System & Finishing Supplies</a>
          </h3>
          <p class="text-xs text-muted leading-relaxed">
            Estimating drywall panels requires measuring total wall and ceiling surface square footage. Standard 4x8 ft panels cover 32 sq ft, while 4x12 ft sheets cover 48 sq ft. Hanging panels horizontally across studs bridges framing irregularities and reduces taped seam length by up to 25%. A complete drywall estimate must account for auxiliary finishing materials: approximately 32 feet of paper joint tape, 38 drywall screws, and 0.05 lbs of joint compound mud per panel.
          </p>
        </div>

        <!-- Pillar 5: Wood Stud Wall Framing & Dimensional Lumber -->
        <div class="space-y-3">
          <h3 class="text-lg font-bold text-ink flex items-center gap-2">
            <span class="text-brand-accent font-bold">5.</span>
            <a href="/calculators/framing-calculator" class="hover:text-brand-accent transition-colors">Wood Stud Wall Framing & Dimensional Lumber</a>
          </h3>
          <p class="text-xs text-muted leading-relaxed">
            Wall framing lumber estimates separate vertical studs from horizontal bottom sole plates and double top plates. Divide total wall length in inches by stud spacing (16" or 24" O.C.) and add 1 end stud, plus 3 extra studs per corner or wall intersection. Plates require continuous 2x4 or 2x6 dimensional lumber runs. Converting total linear footage into standard 16ft commercial lumber sticks minimizes yard scrap waste and keeps jobsite framing budgets accurate.
          </p>
        </div>

        <!-- Pillar 6: Steel Rebar Grid Reinforcement & Lap Splices -->
        <div class="space-y-3">
          <h3 class="text-lg font-bold text-ink flex items-center gap-2">
            <span class="text-brand-accent font-bold">6.</span>
            <a href="/calculators/rebar-calculator" class="hover:text-brand-accent transition-colors">Steel Rebar Grid Reinforcement & Lap Splices</a>
          </h3>
          <p class="text-xs text-muted leading-relaxed">
            Concrete tensile strength is reinforced using steel rebar grids (#3 3/8", #4 1/2", or #5 5/8" bars). Grid calculation requires dividing slab dimensions by grid spacing centers (12" or 18"). When connecting standard 20ft stock rebar sticks, structural building codes enforce a 40d lap splice overlap (40 times the bar diameter). Supporting rebar on chairs elevated in the upper third of the slab guarantees proper concrete encasement and corrosion protection.
          </p>
        </div>

      </div>
    </div>
  </section>

  <!-- Visual FAQ Section for Search Engine & Jobsite Users -->
  <section class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8 border-t border-hairline transition-colors duration-200">
    <div class="bg-canvas border border-hairline rounded-xl p-8 sm:p-12">
      <div class="flex items-center gap-3 mb-8">
        <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-brand-accent/10 text-brand-accent">
          <HelpCircle size={22} />
        </div>
        <div>
          <h2 class="text-2xl sm:text-3xl font-extrabold tracking-tight text-ink">
            Frequently Asked Questions
          </h2>
          <p class="text-xs text-muted mt-1">Jobsite material estimating standards and calculation formulas.</p>
        </div>
      </div>

      <div class="space-y-4">
        {faqItems.map((item) => (
          <div class="bg-surface-card border border-hairline rounded-lg p-6 hover:border-brand-accent/40 transition-colors">
            <h3 class="text-base font-bold text-ink mb-2 flex items-start gap-2">
              <span class="text-brand-accent font-semibold text-lg leading-none">?</span>
              <span>{item.question}</span>
            </h3>
            <p class="text-xs text-muted leading-relaxed pl-5">
              {item.answer}
            </p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Pre-footer CTA Band -->
  <section class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8 transition-colors duration-200">
    <div class="bg-surface-card border border-hairline rounded-lg p-8 sm:p-12 text-center flex flex-col items-center justify-center gap-4">
      <h2 class="text-2xl font-bold tracking-tight text-ink sm:text-3xl">
        Estimate, compile, and print
      </h2>
      <p class="text-sm text-muted max-w-xl leading-relaxed">
        Our integrated jobsite shopping list compiles estimates as you calculate across pages. Print out the full shopping list checklist or export to PDF to take to your local hardware store.
      </p>
      <a
        href="/calculators/concrete-slab-calculator"
        class="mt-4 px-6 py-2.5 bg-brand-accent hover:bg-brand-accent-hover text-white text-sm font-semibold rounded shadow-sm active:scale-95 transition-all duration-100"
      >
        Start Calculators
      </a>
    </div>
  </section>
</BaseLayout>

