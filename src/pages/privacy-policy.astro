---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Shield } from 'lucide-react';

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": "Privacy Policy - Build Yardage",
  "url": "https://buildyardage.com/privacy-policy",
  "description": "Build Yardage Privacy Policy explaining client-side calculations, local storage policies, zero data selling, and web security standards."
};
---

<BaseLayout
  title="Privacy Policy | BuildYardage"
  description="Build Yardage Privacy Policy explaining client-side calculations, local storage policies, zero data selling, and web security standards."
  jsonLd={jsonLd}
>
  <!-- Header Banner -->
  <section class="bg-canvas border-b border-hairline py-12 sm:py-16 transition-colors duration-200">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <nav class="flex text-xs text-muted mb-4 gap-2">
        <a href="/" class="hover:text-ink">Home</a>
        <span>/</span>
        <span class="text-brand-accent font-semibold">Privacy Policy</span>
      </nav>
      <h1 class="text-3xl sm:text-5xl font-extrabold text-ink tracking-tight mb-3 max-w-3xl">
        Privacy Policy
      </h1>
      <p class="text-xs sm:text-sm text-muted">
        Last Updated: July 2026 • BuildYardage.com
      </p>
    </div>
  </section>

  <!-- Legal Body Content -->
  <section class="mx-auto max-w-4xl px-4 py-16 sm:px-6 lg:px-8">
    <div class="bg-canvas border border-hairline rounded-xl p-8 sm:p-12 space-y-10 text-sm text-body leading-relaxed">
      
      <div class="flex items-center gap-3 border-b border-hairline pb-6">
        <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-brand-accent/10 text-brand-accent">
          <Shield size={22} />
        </div>
        <div>
          <h2 class="text-lg font-bold text-ink">Commitment to Your Privacy</h2>
          <p class="text-xs text-muted">Build Yardage is designed as a client-side calculation utility.</p>
        </div>
      </div>

      <div class="space-y-4">
        <h2 class="text-lg font-bold text-ink">1. Information We Do Not Collect</h2>
        <p>
          Build Yardage (<strong>buildyardage.com</strong>) respects jobsite privacy. We do not require account registration, login credentials, passwords, or personal identifying details to access any of our 6 core material estimators or programmatic calculation pages.
        </p>
        <p>
          All volumetric math, tonnage formulas, framing stud counts, drywall coverage algorithms, and rebar lap splice logic execute client-side directly within your browser window.
        </p>
      </div>

      <div class="space-y-4 border-t border-hairline pt-8">
        <h2 class="text-lg font-bold text-ink">2. Local Storage Usage</h2>
        <p>
          To improve jobsite productivity, Build Yardage utilizes standard browser <code class="bg-surface-card border border-hairline px-1.5 py-0.5 rounded text-xs text-brand-accent font-mono">localStorage</code> strictly for the following optional features:
        </p>
        <ul class="list-disc pl-6 space-y-2 text-xs text-muted">
          <li><strong>Recent Calculations History:</strong> Temporarily saving up to 3 of your most recent calculation parameter sets so you can restore them with confirmation popup authorization.</li>
          <li><strong>Theme Preferences:</strong> Saving your selected Dark Mode or Light Mode theme toggle state.</li>
        </ul>
        <p>
          This data remains 100% on your device and is never transmitted to remote servers. You can clear this data at any time by clearing your browser cache.
        </p>
      </div>

      <div class="space-y-4 border-t border-hairline pt-8">
        <h2 class="text-lg font-bold text-ink">3. Analytics & Performance Cookies</h2>
        <p>
          We may analyze anonymized server logs (such as page request volume, browser user-agent types, and HTTP status response codes) strictly for website performance diagnostic optimization, server bandwidth monitoring, and SEO indexation tracking. We do not sell, rent, or trade visitor data to third-party data brokers.
        </p>
      </div>

      <div class="space-y-4 border-t border-hairline pt-8">
        <h2 class="text-lg font-bold text-ink">4. Third-Party Links</h2>
        <p>
          Our site may contain links to external building code reference resources, ASTM standard documentation, or external supply portals. Build Yardage is not responsible for the privacy practices or content of third-party websites.
        </p>
      </div>

      <div class="space-y-4 border-t border-hairline pt-8">
        <h2 class="text-lg font-bold text-ink">5. Privacy Inquiries</h2>
        <p>
          If you have questions regarding this Privacy Policy, please contact us via email at:
        </p>
        <div class="p-4 bg-surface-card border border-hairline rounded-lg text-xs font-mono text-ink">
          Email: <a href="mailto:contact@buildyardage.com" class="text-brand-accent hover:underline">contact@buildyardage.com</a>
        </div>
      </div>

    </div>
  </section>
</BaseLayout>
