---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getTranslations, SUPPORTED_LOCALES, getLocalizedPath, type SupportedLocale } from '../../i18n/utils';
import { ChevronRight, HelpCircle } from 'lucide-react';

export function getStaticPaths() {
  return SUPPORTED_LOCALES.filter((l) => l !== 'en').map((lang) => ({
    params: { lang }
  }));
}

const { lang } = Astro.params;
const activeLang = (lang || 'es') as SupportedLocale;
const t = getTranslations(activeLang);

const faqItems = [
  {
    question: "How many 80lb bags of concrete are in a cubic yard?",
    answer: "There are exactly 45 bags of 80lb pre-mixed concrete in one cubic yard. One 80lb bag yields 0.60 cubic feet of mixed concrete, and 27 cubic feet (1 cubic yard) divided by 0.60 cu ft per bag equals 45 bags (before adding waste margins)."
  },
  {
    question: "How many tons of gravel are in a cubic yard?",
    answer: "There are approximately 1.4 short US tons (2,800 lbs) of crushed gravel or stone in one cubic yard based on standard loose aggregate density (1.40 tons per cu yd). Dense aggregates like crushed granite may reach 1.5 to 1.6 tons per cubic yard."
  },
  {
    question: "How much extra concrete, gravel, or framing material should I order for waste?",
    answer: "Industry standard practice is to order a 10% material waste margin. For concrete, this accounts for uneven sub-grade depth and form flex; for gravel, it covers compaction shrinkage (10%–15%); and for lumber and drywall, it compensates for cuts, headers, and scrap."
  },
  {
    question: "How do I calculate how many studs I need for a framing wall?",
    answer: "To calculate wall studs, convert wall length to inches and divide by stud spacing (16\" or 24\" on-center), then add 1 end stud. Next, add 2–3 extra studs per corner or wall intersection, plus double studs for window or door headers, and apply a 10% waste buffer."
  },
  {
    question: "How do I calculate how many drywall sheets I need for a room?",
    answer: "Calculate total surface area by multiplying wall perimeter by ceiling height, plus room length by width if including the ceiling. Divide total square footage by sheet coverage (32 sq ft for a 4x8 sheet or 48 sq ft for a 4x12 sheet), then add a 10% waste margin for window and door cutouts."
  }
];

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebSite",
      "name": "Build Yardage",
      "url": `https://buildyardage.com/${activeLang}/`,
      "description": t.landing.heroSubtitle
    },
    {
      "@type": "FAQPage",
      "mainEntity": faqItems.map((item) => ({
        "@type": "Question",
        "name": item.question,
        "acceptedAnswer": {
          "@type": "Answer",
          "text": item.answer
        }
      }))
    }
  ]
};
---

<BaseLayout
  title={`${t.landing.seoTitle} | Build Yardage`}
  description={t.landing.heroSubtitle}
  jsonLd={jsonLd}
  lang={activeLang}
>
  <!-- Hero Section -->
  <section class="bg-canvas border-b border-hairline transition-colors duration-200">
    <div class="mx-auto max-w-7xl px-4 py-20 sm:px-6 lg:px-8 text-center">
      <h1 class="text-4xl font-extrabold tracking-tight text-ink sm:text-5xl md:text-6xl max-w-4xl mx-auto leading-[1.1] selection:bg-brand-accent">
        {t.landing.heroTitle}
      </h1>
      <p class="mt-6 text-lg text-muted max-w-2xl mx-auto leading-relaxed">
        {t.landing.heroSubtitle}
      </p>
      
      <!-- CTA Button -->
      <div class="mt-10 flex justify-center gap-4">
        <a
          href={getLocalizedPath('/calculators/concrete-slab-calculator', activeLang)}
          class="flex items-center gap-2 px-6 py-3 bg-brand-primary text-on-primary font-semibold rounded-md shadow hover:bg-brand-primary-active transition-all active:scale-95 duration-100"
        >
          <span>{t.nav.concreteSlab}</span>
          <ChevronRight size={16} />
        </a>
        <a
          href="#directory"
          class="px-6 py-3 border border-hairline bg-canvas text-ink font-semibold rounded-md hover:bg-surface-soft transition-all active:scale-95 duration-100"
        >
          {t.landing.exploreCalculators}
        </a>
      </div>
    </div>
  </section>

  <!-- Calculator Directory Grid -->
  <section id="directory" class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8 transition-colors duration-200">
    <div class="border-b border-hairline pb-5 mb-8">
      <h2 class="text-2xl font-bold tracking-tight text-ink">{t.common.calculators}</h2>
    </div>

    <!-- Cards Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      
      <!-- CARD 1: Concrete Slab -->
      <a href={getLocalizedPath('/calculators/concrete-slab-calculator', activeLang)} class="group bg-canvas border border-hairline hover:border-brand-accent rounded-lg p-6 flex flex-col justify-between hover:shadow-md transition-all duration-200">
        <div>
          <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-indigo-100 dark:bg-indigo-950/60 text-indigo-700 dark:text-indigo-400 mb-4 transition-colors">
            <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 4L21 8.5L12 13L3 8.5Z" />
              <path d="M3 8.5V14.5L12 19V13" />
              <path d="M21 8.5V14.5L12 19" />
            </svg>
          </div>
          <h3 class="text-md font-bold text-ink group-hover:text-brand-accent transition-colors">
            {t.nav.concreteSlab}
          </h3>
          <p class="text-xs text-muted mt-2 leading-relaxed">
            Estimate cubic yards, cubic feet, meters, and pre-mix bag counts (80lb, 60lb, 40lb) with waste margins.
          </p>
        </div>
        <div class="flex items-center gap-1 text-xs font-semibold text-brand-accent mt-6 group-hover:translate-x-1 transition-transform">
          <span>{t.nav.concreteSlab}</span>
          <ChevronRight size={14} />
        </div>
      </a>

      <!-- CARD 2: Concrete Column -->
      <a href={getLocalizedPath('/calculators/concrete-column-calculator', activeLang)} class="group bg-canvas border border-hairline hover:border-brand-accent rounded-lg p-6 flex flex-col justify-between hover:shadow-md transition-all duration-200">
        <div>
          <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-indigo-100 dark:bg-indigo-950/60 text-indigo-700 dark:text-indigo-400 mb-4 transition-colors">
            <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <ellipse cx="12" cy="6" rx="7" ry="2.5" />
              <path d="M5 6V18" />
              <path d="M19 6V18" />
              <path d="M5 18C5 19.38 8.13 20.5 12 20.5C15.87 20.5 19 19.38 19 18" />
            </svg>
          </div>
          <h3 class="text-md font-bold text-ink group-hover:text-brand-accent transition-colors">
            {t.nav.concreteColumn}
          </h3>
          <p class="text-xs text-muted mt-2 leading-relaxed">
            Calculate cylinder volumes for Sonotubes, concrete pillars, fence post holes, and round footings.
          </p>
        </div>
        <div class="flex items-center gap-1 text-xs font-semibold text-brand-accent mt-6 group-hover:translate-x-1 transition-transform">
          <span>{t.nav.concreteColumn}</span>
          <ChevronRight size={14} />
        </div>
      </a>

      <!-- CARD 3: Gravel Base -->
      <a href={getLocalizedPath('/calculators/gravel-driveway-calculator', activeLang)} class="group bg-canvas border border-hairline hover:border-brand-accent rounded-lg p-6 flex flex-col justify-between hover:shadow-md transition-all duration-200">
        <div>
          <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-emerald-100 dark:bg-emerald-950/60 text-emerald-700 dark:text-emerald-400 mb-4 transition-colors">
            <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M4 21C7 15 8 10 10 3" />
              <path d="M20 21C17 15 16 10 14 3" />
              <path d="M12 21C12 17 12 13 12 9" stroke-dasharray="2 3" />
            </svg>
          </div>
          <h3 class="text-md font-bold text-ink group-hover:text-brand-accent transition-colors">
            {t.nav.gravel}
          </h3>
          <p class="text-xs text-muted mt-2 leading-relaxed">
            Determine gravel base tons and cubic yards for driveways, pathways, or sub-bases.
          </p>
        </div>
        <div class="flex items-center gap-1 text-xs font-semibold text-brand-accent mt-6 group-hover:translate-x-1 transition-transform">
          <span>{t.nav.gravel}</span>
          <ChevronRight size={14} />
        </div>
      </a>

      <!-- CARD 4: Drywall Panels -->
      <a href={getLocalizedPath('/calculators/drywall-calculator', activeLang)} class="group bg-canvas border border-hairline hover:border-brand-accent rounded-lg p-6 flex flex-col justify-between hover:shadow-md transition-all duration-200">
        <div>
          <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-amber-100 dark:bg-amber-950/60 text-amber-800 dark:text-amber-400 mb-4 transition-colors">
            <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M7 3H19C19.55 3 20 3.45 20 4V16C20 16.55 19.55 17 19 17H7C6.45 17 6 16.55 6 16V4C6 3.45 6.45 3 7 3Z" opacity="0.4" />
              <rect x="4" y="7" width="13" height="14" rx="1" />
            </svg>
          </div>
          <h3 class="text-md font-bold text-ink group-hover:text-brand-accent transition-colors">
            {t.nav.drywall}
          </h3>
          <p class="text-xs text-muted mt-2 leading-relaxed">
            Calculate drywall sheet quantities, joint paper tape linear feet, screw counts, and bucket mud requirements.
          </p>
        </div>
        <div class="flex items-center gap-1 text-xs font-semibold text-brand-accent mt-6 group-hover:translate-x-1 transition-transform">
          <span>{t.nav.drywall}</span>
          <ChevronRight size={14} />
        </div>
      </a>

      <!-- CARD 5: Wall Framing -->
      <a href={getLocalizedPath('/calculators/framing-calculator', activeLang)} class="group bg-canvas border border-hairline hover:border-brand-accent rounded-lg p-6 flex flex-col justify-between hover:shadow-md transition-all duration-200">
        <div>
          <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-amber-100 dark:bg-amber-950/60 text-amber-800 dark:text-amber-400 mb-4 transition-colors">
            <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="4" y="4" width="16" height="16" rx="1" />
              <line x1="9" y1="4" x2="9" y2="20" />
              <line x1="15" y1="4" x2="15" y2="20" />
            </svg>
          </div>
          <h3 class="text-md font-bold text-ink group-hover:text-brand-accent transition-colors">
            {t.nav.framing}
          </h3>
          <p class="text-xs text-muted mt-2 leading-relaxed">
            Estimate vertical stud counts, corner assemblies, double top plates, and sole plates translated into 16ft lumber sticks.
          </p>
        </div>
        <div class="flex items-center gap-1 text-xs font-semibold text-brand-accent mt-6 group-hover:translate-x-1 transition-transform">
          <span>{t.nav.framing}</span>
          <ChevronRight size={14} />
        </div>
      </a>

      <!-- CARD 6: Rebar Grid -->
      <a href={getLocalizedPath('/calculators/rebar-calculator', activeLang)} class="group bg-canvas border border-hairline hover:border-brand-accent rounded-lg p-6 flex flex-col justify-between hover:shadow-md transition-all duration-200">
        <div>
          <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-indigo-100 dark:bg-indigo-950/60 text-indigo-700 dark:text-indigo-400 mb-4 transition-colors">
            <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M4 8H20M4 16H20M8 4V20M16 4V20" />
            </svg>
          </div>
          <h3 class="text-md font-bold text-ink group-hover:text-brand-accent transition-colors">
            {t.nav.rebar}
          </h3>
          <p class="text-xs text-muted mt-2 leading-relaxed">
            Determine total rebar grid linear footage, 20ft stock bar stick counts, steel weight in pounds, and standard 40d lap splice overlaps.
          </p>
        </div>
        <div class="flex items-center gap-1 text-xs font-semibold text-brand-accent mt-6 group-hover:translate-x-1 transition-transform">
          <span>{t.nav.rebar}</span>
          <ChevronRight size={14} />
        </div>
      </a>

    </div>
  </section>

  <!-- Authoritative SEO Section -->
  <section class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8 border-t border-hairline transition-colors duration-200 content-visibility-auto">
    <div class="bg-canvas border border-hairline rounded-xl p-8 sm:p-12 space-y-8">
      <div>
        <h2 class="text-3xl font-extrabold tracking-tight text-ink sm:text-4xl">
          {t.landing.seoTitle}
        </h2>
        <p class="mt-3 text-sm text-body leading-relaxed">
          Accurate material estimating is the backbone of every profitable construction project, commercial pour, and home renovation. Ordering too little material causes costly jobsite delays, cold joints in concrete, and unexpected delivery fees. Ordering too much wastes capital and clutters your site. Build Yardage provides contractors, trade professionals, and DIY builders with instant, high-precision construction calculators designed strictly around standard building codes and ASTM reference metrics.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 border-t border-hairline pt-8">
        
        <!-- Pillar 1 -->
        <div class="space-y-3">
          <h3 class="text-lg font-bold text-ink flex items-center gap-2">
            <span class="text-brand-accent font-bold">1.</span>
            <a href={getLocalizedPath('/calculators/concrete-slab-calculator', activeLang)} class="hover:text-brand-accent transition-colors">{t.nav.concreteSlab}</a>
          </h3>
          <p class="text-xs text-muted leading-relaxed">
            Volumetric concrete math requires calculating length, width, and thickness in feet, then dividing total cubic feet by 27 to obtain cubic yards. For smaller pours requiring pre-mix bags, one cubic yard yields approximately 45 bags of 80lb concrete, 60 bags of 60lb concrete, or 90 bags of 40lb concrete.
          </p>
        </div>

        <!-- Pillar 2 -->
        <div class="space-y-3">
          <h3 class="text-lg font-bold text-ink flex items-center gap-2">
            <span class="text-brand-accent font-bold">2.</span>
            <a href={getLocalizedPath('/calculators/concrete-column-calculator', activeLang)} class="hover:text-brand-accent transition-colors">{t.nav.concreteColumn}</a>
          </h3>
          <p class="text-xs text-muted leading-relaxed">
            Cylindrical footings, Sonotube cardboard forms, and round fence post holes follow strict cylinder volume geometry (Volume = π × r² × h). The radius represents half the hole diameter in feet, while height measures depth below grade.
          </p>
        </div>

        <!-- Pillar 3 -->
        <div class="space-y-3">
          <h3 class="text-lg font-bold text-ink flex items-center gap-2">
            <span class="text-brand-accent font-bold">3.</span>
            <a href={getLocalizedPath('/calculators/gravel-driveway-calculator', activeLang)} class="hover:text-brand-accent transition-colors">{t.nav.gravel}</a>
          </h3>
          <p class="text-xs text-muted leading-relaxed">
            Quarries sell gravel, crushed stone, granite, and sand by weight in short US tons rather than cubic yards. Volume-to-weight conversions require multiplying cubic yards by specific aggregate material density factors.
          </p>
        </div>

        <!-- Pillar 4 -->
        <div class="space-y-3">
          <h3 class="text-lg font-bold text-ink flex items-center gap-2">
            <span class="text-brand-accent font-bold">4.</span>
            <a href={getLocalizedPath('/calculators/drywall-calculator', activeLang)} class="hover:text-brand-accent transition-colors">{t.nav.drywall}</a>
          </h3>
          <p class="text-xs text-muted leading-relaxed">
            Estimating drywall panels requires measuring total wall and ceiling surface square footage. Standard 4x8 ft panels cover 32 sq ft, while 4x12 ft sheets cover 48 sq ft.
          </p>
        </div>

        <!-- Pillar 5 -->
        <div class="space-y-3">
          <h3 class="text-lg font-bold text-ink flex items-center gap-2">
            <span class="text-brand-accent font-bold">5.</span>
            <a href={getLocalizedPath('/calculators/framing-calculator', activeLang)} class="hover:text-brand-accent transition-colors">{t.nav.framing}</a>
          </h3>
          <p class="text-xs text-muted leading-relaxed">
            Wall framing lumber estimates separate vertical studs from horizontal bottom sole plates and double top plates. Divide total wall length in inches by stud spacing (16" or 24" O.C.) and add 1 end stud.
          </p>
        </div>

        <!-- Pillar 6 -->
        <div class="space-y-3">
          <h3 class="text-lg font-bold text-ink flex items-center gap-2">
            <span class="text-brand-accent font-bold">6.</span>
            <a href={getLocalizedPath('/calculators/rebar-calculator', activeLang)} class="hover:text-brand-accent transition-colors">{t.nav.rebar}</a>
          </h3>
          <p class="text-xs text-muted leading-relaxed">
            Concrete tensile strength is reinforced using steel rebar grids (#3 3/8", #4 1/2", or #5 5/8" bars). Grid calculation requires dividing slab dimensions by grid spacing centers.
          </p>
        </div>

      </div>
    </div>
  </section>

  <!-- Visual FAQ Section -->
  <section class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8 border-t border-hairline transition-colors duration-200">
    <div class="bg-canvas border border-hairline rounded-xl p-8 sm:p-12">
      <div class="flex items-center gap-3 mb-8">
        <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-brand-accent/10 text-brand-accent">
          <HelpCircle size={22} />
        </div>
        <div>
          <h2 class="text-2xl sm:text-3xl font-extrabold tracking-tight text-ink">
            {t.landing.faqTitle}
          </h2>
        </div>
      </div>

      <div class="space-y-6">
        {faqItems.map((faq) => (
          <div class="border-b border-hairline pb-6 last:border-b-0 last:pb-0">
            <h3 class="text-base font-bold text-ink mb-2">{faq.question}</h3>
            <p class="text-xs text-muted leading-relaxed">{faq.answer}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
