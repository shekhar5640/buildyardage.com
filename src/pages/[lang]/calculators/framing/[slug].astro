---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import FramingCalculator from '../../../../components/FramingCalculator';
import ToolGuideSection from '../../../../components/ToolGuideSection.astro';
import { getFramingPseoPages, type PseoPageData } from '../../../../data/pseo/pseoMatrix';
import { SUPPORTED_LOCALES, LOCALES, getTranslations, getLocalizedPath, type SupportedLocale } from '../../../../i18n/utils';

export async function getStaticPaths() {
  const NON_DEFAULT_LOCALES = SUPPORTED_LOCALES.filter((l) => l !== 'en');
  const pages = getFramingPseoPages();
  const paths = [];

  for (const lang of NON_DEFAULT_LOCALES) {
    for (const page of pages) {
      paths.push({
        params: { lang, slug: page.slug },
        props: { pageData: page }
      });
    }
  }

  return paths;
}

interface Props {
  pageData: PseoPageData;
}

const { lang } = Astro.params;
const { pageData } = Astro.props;
const activeLang = (lang || 'es') as SupportedLocale;
const t = getTranslations(activeLang);

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "SoftwareApplication",
      "name": pageData.metaTitle,
      "operatingSystem": "All",
      "applicationCategory": "BusinessApplication"
    },
    {
      "@type": "FAQPage",
      "mainEntity": pageData.faqs.map(f => ({
        "@type": "Question",
        "name": f.question,
        "acceptedAnswer": {
          "@type": "Answer",
          "text": f.answer
        }
      }))
    }
  ]
};
---

<BaseLayout
  title={`${pageData.slug} | ${t.nav.framing}`}
  description={pageData.metaDescription}
  jsonLd={jsonLd}
  lang={activeLang}
>
  <div class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8 space-y-12">
    <nav class="flex text-xs text-muted gap-2">
      <a href={getLocalizedPath('/', activeLang)} class="hover:text-ink">{t.common.home}</a>
      <span>/</span>
      <a href={getLocalizedPath('/calculators/framing-calculator', activeLang)} class="hover:text-ink">{t.nav.framing}</a>
      <span>/</span>
      <span class="text-brand-accent font-semibold">{pageData.slug}</span>
    </nav>

    <FramingCalculator
      client:load
      initialWallLength={pageData.inputs.length}
      initialStudSpacing={pageData.inputs.studSpacing}
      initialIsMetric={LOCALES[activeLang].isMetricDefault}
    />

    <ToolGuideSection slug="framing-calculator" />
  </div>
</BaseLayout>
