---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { SUPPORTED_LOCALES, getTranslations, type SupportedLocale } from '../../i18n/utils';
import { FileText } from 'lucide-react';

export function getStaticPaths() {
  return SUPPORTED_LOCALES.filter((l) => l !== 'en').map((lang) => ({
    params: { lang }
  }));
}

const { lang } = Astro.params;
const activeLang = (lang || 'es') as SupportedLocale;
const t = getTranslations(activeLang);

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": `${t.terms.title} - Build Yardage`,
  "url": `https://buildyardage.com/${activeLang}/terms-and-conditions`
};
---

<BaseLayout
  title={`${t.terms.title} | Build Yardage`}
  description={t.terms.intro}
  jsonLd={jsonLd}
  lang={activeLang}
>
  <section class="bg-canvas border-b border-hairline py-12 sm:py-16 transition-colors duration-200">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <nav class="flex text-xs text-muted mb-4 gap-2">
        <a href="/" class="hover:text-ink">{t.common.home}</a>
        <span>/</span>
        <span class="text-brand-accent font-semibold">{t.terms.title}</span>
      </nav>
      <h1 class="text-3xl sm:text-5xl font-extrabold text-ink tracking-tight mb-3 max-w-3xl">
        {t.terms.title}
      </h1>
      <p class="text-xs font-mono text-muted">{t.terms.lastUpdated}</p>
    </div>
  </section>

  <section class="mx-auto max-w-4xl px-4 py-16 sm:px-6 lg:px-8 space-y-8">
    <p class="text-sm text-body leading-relaxed">{t.terms.intro}</p>

    <div class="space-y-4">
      <h2 class="text-lg font-bold text-ink">{t.terms.disclaimerTitle}</h2>
      <p class="text-xs text-muted leading-relaxed">{t.terms.disclaimerDesc}</p>
    </div>

    <div class="space-y-4">
      <h2 class="text-lg font-bold text-ink">{t.terms.liabilityTitle}</h2>
      <p class="text-xs text-muted leading-relaxed">{t.terms.liabilityDesc}</p>
    </div>

    <div class="space-y-4">
      <h2 class="text-lg font-bold text-ink">{t.terms.ipTitle}</h2>
      <p class="text-xs text-muted leading-relaxed">{t.terms.ipDesc}</p>
    </div>
  </section>
</BaseLayout>
