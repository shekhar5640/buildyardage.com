---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ConcreteSlabCalculator from '../../../components/ConcreteSlabCalculator';
import ToolGuideSection from '../../../components/ToolGuideSection.astro';
import { getConcreteSlabPseoPages, type PseoPageData } from '../../../data/pseo/pseoMatrix';

export async function getStaticPaths() {
  const pages = getConcreteSlabPseoPages();
  return pages.map((page) => ({
    params: { slug: page.slug },
    props: { pageData: page }
  }));
}

interface Props {
  pageData: PseoPageData;
}

const { pageData } = Astro.props;

// Construct JSON-LD Schemas
const webAppSchema = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": pageData.metaTitle,
  "operatingSystem": "All",
  "applicationCategory": "BusinessApplication",
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "USD"
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": pageData.faqs.map(f => ({
    "@type": "Question",
    "name": f.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": f.answer
    }
  }))
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://buildyardage.com" },
    { "@type": "ListItem", "position": 2, "name": "Calculators", "item": "https://buildyardage.com/calculators/concrete-slab-calculator" },
    { "@type": "ListItem", "position": 3, "name": "Concrete Slab", "item": `https://buildyardage.com${pageData.urlPath}` }
  ]
};

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [webAppSchema, faqSchema, breadcrumbSchema]
};
---

<BaseLayout title={pageData.metaTitle} description={pageData.metaDescription} jsonLd={jsonLd}>
  <div class="bg-canvas border-b border-hairline py-10 transition-colors duration-200">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      
      <!-- Breadcrumbs -->
      <nav class="flex text-xs text-muted mb-4 gap-2">
        <a href="/" class="hover:text-ink">Home</a>
        <span>/</span>
        <a href="/calculators/concrete-slab-calculator" class="hover:text-ink">Concrete Slab Calculator</a>
        <span>/</span>
        <span class="text-brand-accent font-semibold">{pageData.slug}</span>
      </nav>

      <!-- Target H1 Title -->
      <h1 class="text-3xl sm:text-4xl font-extrabold text-ink tracking-tight mb-3 max-w-4xl">
        {pageData.h1Title}
      </h1>
      <p class="text-sm text-body leading-relaxed max-w-3xl mb-8">
        Instant, pre-calculated material breakdown for a {pageData.inputs.length}ft × {pageData.inputs.width}ft concrete slab at {pageData.inputs.thickness} inches depth. Automatically factors in ASTM volumetric standards and a 10% jobsite waste buffer.
      </p>

      <!-- Interactive Calculator Island Pre-filled -->
      <ConcreteSlabCalculator 
        initialLength={pageData.inputs.length} 
        initialWidth={pageData.inputs.width} 
        initialThickness={pageData.inputs.thickness} 
        client:load 
      />

      <!-- Quick Answer Summary Box -->
      <div class="mt-8 bg-brand-accent/10 border border-brand-accent/30 rounded-xl p-6 shadow-xs max-w-7xl">
        <div class="flex items-start gap-3">
          <span class="text-brand-accent font-bold text-xl">💡</span>
          <div>
            <h2 class="text-sm font-bold uppercase tracking-wider text-brand-accent mb-1">Quick Answer Summary</h2>
            <p class="text-base text-ink font-semibold leading-relaxed">
              {pageData.quickAnswer}
            </p>
          </div>
        </div>
      </div>

    </div>
  </div>

  <!-- Programmatic Educational & Math Section -->
  <section class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8 space-y-12">
    
    <!-- LaTeX Math Formula Breakdown -->
    <div class="bg-canvas border border-hairline rounded-xl p-6 sm:p-8">
      <h2 class="text-2xl font-extrabold text-ink tracking-tight mb-2">
        {pageData.latexMath.title}
      </h2>
      <p class="text-xs text-muted mb-4">Exact mathematical formula used to compute your required concrete yardage and bag counts.</p>
      
      <div class="bg-surface-card border border-hairline rounded-lg p-4 font-mono text-sm text-brand-accent mb-4 overflow-x-auto">
        <code>{pageData.latexMath.formula}</code>
      </div>
      <p class="text-xs text-body leading-relaxed">
        {pageData.latexMath.explanation}
      </p>
    </div>

    <!-- Material Estimating Cheat Sheet (Comparative Table) -->
    <div class="bg-canvas border border-hairline rounded-xl p-6 sm:p-8">
      <h2 class="text-2xl font-extrabold text-ink tracking-tight mb-2">
        Concrete Slab Material Cheat Sheet
      </h2>
      <p class="text-xs text-muted mb-6">Compare concrete volume and 80lb bag counts for neighboring slab sizes at {pageData.inputs.thickness}" depth.</p>
      
      <div class="overflow-x-auto">
        <table class="w-full text-left text-xs border-collapse">
          <thead>
            <tr class="border-b border-hairline text-muted uppercase tracking-wider font-semibold">
              {pageData.comparativeTable.headers.map(h => (
                <th class="py-3 px-4">{h}</th>
              ))}
            </tr>
          </thead>
          <tbody class="divide-y divide-hairline">
            {pageData.comparativeTable.rows.map(r => (
              <tr class="hover:bg-surface-soft transition-colors">
                <td class="py-3 px-4 font-bold text-ink">
                  {r.url ? <a href={r.url} class="hover:text-brand-accent underline decoration-dotted">{r.label}</a> : r.label}
                </td>
                <td class="py-3 px-4 text-body font-mono">{r.volumeOrQty}</td>
                <td class="py-3 px-4 text-body font-mono">{r.bagsOrSticks}</td>
                <td class="py-3 px-4 text-brand-accent font-mono font-semibold">{r.estCostRange}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>

    <!-- Jobsite Tips -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {pageData.jobsiteTips.map(tip => (
        <div class="bg-canvas border border-hairline rounded-lg p-5">
          <h3 class="text-sm font-bold text-ink mb-1.5 flex items-center gap-2">
            <span class="text-brand-accent">★</span>
            <span>{tip.title}</span>
          </h3>
          <p class="text-xs text-muted leading-relaxed">{tip.desc}</p>
        </div>
      ))}
    </div>

    <!-- Programmatic FAQs Section -->
    <div class="bg-surface-card border border-hairline rounded-xl p-6 sm:p-8">
      <h2 class="text-2xl font-extrabold text-ink tracking-tight mb-6">
        Frequently Asked Questions
      </h2>
      <div class="space-y-4">
        {pageData.faqs.map(faq => (
          <div class="bg-canvas border border-hairline rounded-lg p-5">
            <h3 class="text-sm font-bold text-ink mb-2">
              {faq.question}
            </h3>
            <p class="text-xs text-muted leading-relaxed">
              {faq.answer}
            </p>
          </div>
        ))}
      </div>
    </div>

    <!-- Cross-Tool Interlinking & Silo Navigation -->
    <div class="border-t border-hairline pt-8 space-y-6">
      <h3 class="text-sm font-bold uppercase text-muted tracking-wider">Related Estimators & Nearby Sizes</h3>
      
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        {pageData.crossToolLinks.map(link => (
          <a href={link.url} class="bg-canvas border border-hairline hover:border-brand-accent rounded-lg p-4 transition-all flex items-center justify-between group">
            <div>
              <span class="text-[10px] font-bold text-brand-accent uppercase tracking-wider block mb-0.5">{link.category}</span>
              <span class="text-xs font-bold text-ink group-hover:text-brand-accent transition-colors">{link.title}</span>
            </div>
            <span class="text-xs text-brand-accent group-hover:translate-x-1 transition-transform">&rarr;</span>
          </a>
        ))}
      </div>
    </div>

  </section>

  <!-- Base Tool Guides Below -->
  <ToolGuideSection slug="concrete-slab-calculator" />
</BaseLayout>
