---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Calculator from '../../components/Calculator';
import AdCard from '../../components/AdCard';
import materials from '../../data/materials.json';

export async function getStaticPaths() {
  return materials.map((item) => ({
    params: { slug: item.slug },
    props: { item },
  }));
}

const { item } = Astro.props;

// Generate dynamic JSON-LD SoftwareApplication structured data for rich snippets on Google
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": item.meta_title,
  "operatingSystem": "All",
  "applicationCategory": "BusinessApplication",
  "description": item.meta_description,
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "USD"
  }
};
---

<BaseLayout 
  title={item.meta_title} 
  description={item.meta_description}
  jsonLd={jsonLd}
>
  <!-- Hero Section -->
  <section class="no-print bg-canvas border-b border-hairline transition-colors duration-200">
    <div class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8 text-center md:text-left flex flex-col md:flex-row items-center justify-between gap-6">
      <div class="max-w-2xl">
        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-brand-accent/10 text-brand-accent dark:text-indigo-400 text-xs font-semibold mb-4">
          <span class="flex h-2 w-2 rounded-full bg-brand-accent animate-pulse"></span>
          <span>100% Free Contractor Tool</span>
        </div>
        <h1 class="text-3xl font-bold tracking-tight text-ink sm:text-4xl">
          {item.material} <span class="text-brand-accent">{item.shape}</span> Calculator
        </h1>
        <p class="mt-3 text-md text-muted leading-relaxed">
          Get highly precise calculations for your next construction or DIY project. Enter your jobsite measurements below for instant yards, tonnage, plates, or bag estimates.
        </p>
      </div>
      
      <!-- Quick Info Badges -->
      <div class="flex flex-wrap gap-3 justify-center md:justify-end shrink-0">
        <div class="bg-surface-card border border-hairline px-4 py-3 rounded-lg flex flex-col items-center min-w-[100px]">
          <span class="text-[10px] font-bold uppercase text-muted tracking-wider">Precision</span>
          <span class="text-sm font-mono font-extrabold text-ink mt-0.5">High</span>
        </div>
        <div class="bg-surface-card border border-hairline px-4 py-3 rounded-lg flex flex-col items-center min-w-[100px]">
          <span class="text-[10px] font-bold uppercase text-muted tracking-wider">Standard</span>
          <span class="text-sm font-mono font-extrabold text-ink mt-0.5">ASTM C94</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Interactive Calculator Component -->
  <div class="bg-canvas/50 transition-colors duration-200">
    <Calculator 
      client:load 
      slug={item.slug}
      material={item.material}
      shape={item.shape}
      type={item.type}
      defaultWastePercent={item.default_waste_percent}
      defaultThickness={item.default_thickness}
    />
  </div>

  <!-- Content & Ad Section below calculator -->
  <section class="no-print mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8 border-t border-hairline transition-colors duration-200">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-start">
      
      <!-- LSI Editorial Content (8 cols to prevent search-engine thin content penalties) -->
      <article class="lg:col-span-8 space-y-6">
        <div class="bg-canvas border border-hairline rounded-lg p-6 sm:p-8">
          <h2 class="text-xl font-bold tracking-tight text-ink mb-4">
            {item.lsi_title}
          </h2>
          <div class="text-sm text-body leading-relaxed space-y-4">
            <p>{item.lsi_text}</p>
            
            <h3 class="text-md font-semibold text-ink mt-6 mb-2">How to Estimate Materials Correctly</h3>
            <p>
              When planning a material purchase, ordering the exact mathematical volume often leads to shortages due to form bowing, settling, soil unevenness, and spills. We recommend applying a standard waste margin buffer:
            </p>
            <ul class="list-disc pl-5 space-y-1.5 mt-2">
              <li><strong>Slabs & Driveways:</strong> 10% waste buffer to account for sub-grade variation.</li>
              <li><strong>Columns & Sonotubes:</strong> 5% to 10% waste buffer depending on hole smoothness.</li>
              <li><strong>Gravel Bases:</strong> 10% to 15% to compensate for compaction sinking.</li>
              <li><strong>Drywall:</strong> 10% to accommodate cuts, off-angles, and window headers.</li>
              <li><strong>Wood Framing:</strong> 10% for header blocks, plate waste, and warped studs.</li>
            </ul>
          </div>
        </div>
      </article>

      <!-- Sidebar Native Ads (4 cols) -->
      <aside class="lg:col-span-4 flex flex-col gap-6">
        <AdCard client:load />
        
        <div class="bg-surface-card border border-hairline rounded-lg p-5">
          <h4 class="text-xs font-bold uppercase text-muted tracking-wider">How to Use Results</h4>
          <p class="text-xs text-muted mt-2 leading-relaxed">
            All volume and pieces results are compiled live into the **Jobsite Shopping List** sidebar. Click the add button to keep track of aggregates across pages. You can print the compiled list or save it as a PDF printout.
          </p>
        </div>
      </aside>

    </div>
  </section>
</BaseLayout>
