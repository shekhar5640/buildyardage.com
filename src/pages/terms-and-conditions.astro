---
import BaseLayout from '../layouts/BaseLayout.astro';
import { FileText } from 'lucide-react';

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": "Terms and Conditions - Build Yardage",
  "url": "https://buildyardage.com/terms-and-conditions",
  "description": "Build Yardage Terms and Conditions of Use detailing calculation disclaimers, contractor field verification recommendations, and intellectual property terms."
};
---

<BaseLayout
  title="Terms & Conditions | BuildYardage"
  description="Build Yardage Terms and Conditions of Use detailing calculation disclaimers, contractor field verification recommendations, and intellectual property terms."
  jsonLd={jsonLd}
>
  <!-- Header Banner -->
  <section class="bg-canvas border-b border-hairline py-12 sm:py-16 transition-colors duration-200">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <nav class="flex text-xs text-muted mb-4 gap-2">
        <a href="/" class="hover:text-ink">Home</a>
        <span>/</span>
        <span class="text-brand-accent font-semibold">Terms & Conditions</span>
      </nav>
      <h1 class="text-3xl sm:text-5xl font-extrabold text-ink tracking-tight mb-3 max-w-3xl">
        Terms & Conditions of Use
      </h1>
      <p class="text-xs sm:text-sm text-muted">
        Last Updated: July 2026 • BuildYardage.com
      </p>
    </div>
  </section>

  <!-- Legal Body Content -->
  <section class="mx-auto max-w-4xl px-4 py-16 sm:px-6 lg:px-8">
    <div class="bg-canvas border border-hairline rounded-xl p-8 sm:p-12 space-y-10 text-sm text-body leading-relaxed">
      
      <div class="flex items-center gap-3 border-b border-hairline pb-6">
        <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-brand-accent/10 text-brand-accent">
          <FileText size={22} />
        </div>
        <div>
          <h2 class="text-lg font-bold text-ink">Terms of Agreement</h2>
          <p class="text-xs text-muted">Please review these terms before using BuildYardage.com tools.</p>
        </div>
      </div>

      <div class="space-y-4">
        <h2 class="text-lg font-bold text-ink">1. Acceptance of Terms</h2>
        <p>
          By accessing and using Build Yardage (<strong>buildyardage.com</strong>), you agree to be bound by these Terms and Conditions. If you do not agree to these terms, please discontinue use of our site and calculation tools.
        </p>
      </div>

      <div class="space-y-4 border-t border-hairline pt-8">
        <h2 class="text-lg font-bold text-ink">2. Estimation Disclaimer & Field Verification</h2>
        <p class="bg-surface-card border border-hairline p-4 rounded-lg text-xs leading-relaxed text-muted">
          <strong class="text-ink font-semibold block mb-1">IMPORTANT NOTICE FOR CONTRACTORS & BUILDERS:</strong>
          All estimates generated by Build Yardage (including cubic yards, bag counts, tonnage, stud counts, drywall sheet quantities, and rebar linear footage) are mathematical estimates based on standard nominal formulas, user-entered parameters, and standard waste factors.
        </p>
        <p>
          Actual jobsite material requirements may vary based on soil excavation irregularities, form deflection, compaction ratios, structural engineer specifications, local building department code amendments, and physical material dimensions. Users must verify field measurements and consult a licensed contractor or structural engineer prior to placing commercial material orders.
        </p>
      </div>

      <div class="space-y-4 border-t border-hairline pt-8">
        <h2 class="text-lg font-bold text-ink">3. Limitation of Liability</h2>
        <p>
          Under no circumstances shall Build Yardage, its owners, operators, or contributors be held liable for any direct, indirect, incidental, consequential, or financial damages arising from the use of, or inability to use, our estimators, including but not limited to material shortages, excess ordering expenses, jobsite labor delays, or structural failure.
        </p>
      </div>

      <div class="space-y-4 border-t border-hairline pt-8">
        <h2 class="text-lg font-bold text-ink">4. Intellectual Property</h2>
        <p>
          The custom user interface components, calculation engine code, site layout, graphics, programmatic matrix architecture, and branding are the property of Build Yardage and are protected by applicable copyright, trademark, and intellectual property laws.
        </p>
      </div>

      <div class="space-y-4 border-t border-hairline pt-8">
        <h2 class="text-lg font-bold text-ink">5. Inquiries & Legal Contact</h2>
        <p>
          For legal notice or terms inquiries, please contact us at:
        </p>
        <div class="p-4 bg-surface-card border border-hairline rounded-lg text-xs font-mono text-ink">
          Email: <a href="mailto:contact@buildyardage.com" class="text-brand-accent hover:underline">contact@buildyardage.com</a>
        </div>
      </div>

    </div>
  </section>
</BaseLayout>
